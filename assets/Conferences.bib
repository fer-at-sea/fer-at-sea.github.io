@misc{fer_WSC,
	title = {Merging scales and methodologies: from underwater tow cameras to {Sentinel}-2 imagery to assess seagrass distribution},
	copyright = {Creative Commons Attribution 4.0 International},
	shorttitle = {Merging scales and methodologies},
	url = {https://zenodo.org/doi/10.5281/zenodo.12513770},
	doi = {10.5281/ZENODO.12513770},
	abstract = {The implementation of large-scale seagrass monitoring programmes (e.g. EU Marine Strategy Framework Directive) requires protocols and methodologies to provide reliable and replicable habitat quality assessments over broad geographical areas. As new platforms emerge and artificial intelligence evolves, the potential of optical remote sensing to monitor seagrass cover, recognized as an Essential Ocean Variable (EOV), is undeniable. In this context, quality ground-truth observations are essential to train and validate machine learning models.

We have developed a robust methodology to capture extensive ground-truth data using underwater towed-cameras that are subsequently coupled with Sentinel-2 imagery. Seagrass species and bottom types are clearly identified in underwater recordings as the geolocated camera travels near the seabed. Georeferenced observations are extracted from the videos and combined with satellite imagery to train machine learning models and evaluate the accuracy of ensuing habitat cartographies.

This methodology was used to assess seagrass distribution in Es Freus, a Marine Protected Area in the western Mediterranean. We particularly focus on Cymodocea nodosa, a highly dynamic species with marked seasonal distribution shifts. Updated ground-truth data proved crucial for mapping this challenging species. This work is part of a wider study to evaluate this EOV (seagrass cover) in the MPA using Sentinel-2.},
	urldate = {2026-05-06},
	journal = {World Seagrass Conference \& 15th International Seagrass Biology Workshop (WSC - ISBW)},
	author = {Garcia-Gonzalez, Fernando and Bernardeau Esteller, Jaime and Martínez-Garrido, Jose and Rojo, Irene and Belando Torrentes, Maria Dolores and García Sánchez, Marta and Mompeán de la Rosa, Carmen and García-Muñoz, Rocío and Marín-Guirao, Lazaro and Ruiz Fernandez, Juan Manuel},
	month = jul,
	year = {2024},
	file = {PDF:/Users/fer/Zotero/storage/RUUP54WH/Garcia-Gonzalez et al. - 2024 - Merging scales and methodologies from underwater tow cameras to Sentinel-2 imagery to assess seagra.pdf:application/pdf},
}

@misc{garcia-gonzalezIntegracionSentinel2Evaluacion2024,
	title = {Integración de {Sentinel}-2 en la evaluación del estado de las praderas de {Posidonia} oceanica},
	copyright = {Creative Commons Attribution 4.0 International},
	url = {https://zenodo.org/doi/10.5281/zenodo.12257722},
	doi = {10.5281/ZENODO.12257722},
	abstract = {Large scale monitoring programs of Posidonia oceanica require novel techniques that allow for the effective and replicable assessment of meadow environmental status. In this context, shallow water remote sensing emerges as a key tool, capable of addressing one of the main indicators of habitat status: the characterization and evolution of meadow distribution limits. Below, we outline a methodology for monitoring the shallow limits of P. oceanica through supervised classification of Sentinel-2. Additionally, two case studies are presented, where the benthic cartographies obtained exceed 92\% accuracy, also offering superior spatial resolution compared to pre-existing maps. These results show that integrating remote sensing with traditional in situ sampling techniques enhances the monitoring capacity of shallow limits, providing relevant information for assessing the status of P. oceanica meadows. This approach not only expands the scope of action but also significantly reduces monitoring costs},
	urldate = {2026-05-06},
	journal = {XX Congreso de la Asociación Española de Teledetección},
	author = {Garcia-Gonzalez, Fernando and Bernardeau Esteller, Jaime and Martínez-Garrido, Jose and Rojo, Irene and Dalmau Martinez, Andreu and Belando Torrentes, Maria Dolores and García Sánchez, Marta and Mompeán de la Rosa, Carmen and García-Muñoz, Rocío and Marín-Guirao, Lázaro and Quirós, Elia and Boada, Jordi and Ruiz Fernández, Juan Manuel},
	month = jun,
	year = {2024},
	file = {PDF:/Users/fer/Zotero/storage/HJM2UDG6/Garcia-Gonzalez et al. - 2024 - Integración de Sentinel-2 en la evaluación del estado de las praderas de Posidonia oceanica.pdf:application/pdf},
}

@misc{pep_WSC,
	title = {A novel approach to monitor the deep limits of {Posidonia} oceanica meadows: seascape analysis using high-resolution underwater orthomosaics.},
	copyright = {Creative Commons Attribution 4.0 International},
	shorttitle = {A novel approach to monitor the deep limits of {Posidonia} oceanica meadows},
	url = {https://zenodo.org/doi/10.5281/zenodo.14281038},
	doi = {10.5281/ZENODO.14281038},
	abstract = {The deep margins of Posidonia oceanica meadows are close to the physiological thresholds of the species, making them particularly sensitive to anthropogenic pressures and climate change. Accurate monitoring of these edges is critical to assess the evolution and conservation of this valuable habitat within the EU Marine Strategy Framework Directive. Such monitoring, however, has so far been challenging due to limitations imposed by depth. Here we present a novel approach to characterize and monitor four P. oceanica deep-meadow margins (22-28 m) using an Autonomous Underwater Vehicle (AUV). The AUV was deployed at each site to record over 1,000 georeferenced images that were subsequently merged into centimeter-resolution orthomosaics covering 600 m² each. These mosaics were then classified using Random Forest, yielding seagrass distribution maps with over 80\% accuracy. The resulting maps were used to analyze the spatial structure of the meadow through quantitative seascape metrics that showed strong correlation with classic descriptors of meadow structure. Results were also consistent with the conservation status of each of the meadows studied. 

Findings evidence the great value of this new methodology for successfully characterizing the conservation status of deep P. oceanica margins and for accurately detecting distribution changes and fragmentation processes.},
	urldate = {2026-05-06},
	journal = {World Seagrass Conference \& 15th International Seagrass Biology Workshop (WSC - ISBW)},
	author = {Martínez-Garrido, Jose and Garcia-Gonzalez, Fernando and Bernardeau Esteller, Jaime and Arteaga Michaux, Sayri and Garcia, Meidi and Navarro-Martínez, Pedro and Marín-Guirao, Lazaro and Belando Torrentes, Maria Dolores and Rojo, Irene and García-Sánchez, Marta and Mompeán de la Rosa, Carmen and García-Muñoz, Rocío and Ruiz Fernández, Juan Manuel},
	month = jul,
	year = {2024},
	file = {PDF:/Users/fer/Zotero/storage/M3P65TBZ/Martínez-Garrido et al. - 2024 - A novel approach to monitor the deep limits of Posidonia oceanica meadows seascape analysis using h.pdf:application/pdf},
}
